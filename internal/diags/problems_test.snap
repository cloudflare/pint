[TestInjectDiagnostics/YAML_literal_block_scalar - 1]

expr: |
  sum(bar{job="foo"})
  / on(c,d)
  sum(bar)


3 |   sum(bar{job="foo"})
4 |   / on(c,d)
        ^^ 123
5 |   sum(bar)
      ^^^ 456

