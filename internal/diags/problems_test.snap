[TestInjectDiagnostics/multi-line_expression_skips_AST_trimming - 1]

expr: |
  sum(rate(very_long_metric_name_that_pushes_past_the_width_limit_aaaa{job="api",status=~"5.."}[5m])) by(instance)
  + sum(rate(another_very_long_metric_name_that_pushes_past_the_width_limit{job="api"}[5m]))

3 |   sum(rate(very_long_metric_name_that_pushes_past_the_width_limit_aaaa{job="api",status=~"5.."}[5m])) by(instance)
        ^^^^^^ bad rate
4 |   + sum(rate(another_very_long_metric_name_that_pushes_past_the_width_limit{job="api"}[5m]))

