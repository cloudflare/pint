[TestInjectDiagnostics/two_diagnostics_on_different_columns - 1]

expr: sum(foo{job="bar"})
      / on(a,b)
      sum(foo)


2 | expr: sum(foo{job="bar"})
3 |       / on(a,b)
               ^^^ efg
            ^^^^^^^ abc
4 |       sum(foo)

