[TestRuleName/alerting_rule_name_doesn't_match_snake_case_regex - 1]
- description: alerting rule name doesn't match snake_case regex
  content: |
    - alert: CockroachDB_High_CPU_Usage
      expr: sum(foo) without()
  output: |
    1 | - alert: CockroachDB_High_CPU_Usage
                 ^^^^^^^^^^^^^^^^^^^^^^^^^^ alerting rule name must match `^[a-z_]+$`.
  problem:
    reporter: rule/name
    summary: name not allowed
    details: 'Rule comment: Alert names must use snake_case'
    diagnostics:
        - message: alerting rule name must match `^[a-z_]+$`.
          firstcolumn: 1
          lastcolumn: 26
          kind: 0
    lines:
        first: 1
        last: 1
    severity: 1
    anchor: 0

