[TestFeaturesCheck/buildinfo_bad_version - 1]
- description: buildinfo bad version
  content: |
    - record: foo
      expr: mad_over_time(bar[5m])
  output: |
    1 | - record: foo
                  ^^^ Couldn't run some online checks due to "prom" error: `failed to parse Prometheus version "not-a-version": expected major.minor.patch format`.
  problem:
    reporter: promql/features
    summary: unable to run checks
    details: ""
    diagnostics:
        - message: 'Couldn''t run some online checks due to "prom" error: `failed to parse Prometheus version "not-a-version": expected major.minor.patch format`.'
          firstcolumn: 1
          lastcolumn: 3
          kind: 0
    lines:
        first: 1
        last: 2
    severity: 1
    anchor: 0

