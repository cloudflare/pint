
[TestGetChecksForRule/multiple_cost_checks - 1]
title: multiple cost checks
config: |-
    {
      "ci": {
        "baseBranch": "master",
        "maxCommits": 20
      },
      "parser": {},
      "repository": {},
      "checks": {
        "enabled": [
          "alerts/absent",
          "alerts/annotation",
          "alerts/comparison",
          "alerts/count",
          "alerts/external_labels",
          "alerts/for",
          "alerts/template",
          "labels/conflict",
          "promql/aggregate",
          "promql/counter",
          "promql/features",
          "promql/fragile",
          "group/interval",
          "promql/impossible",
          "promql/range_query",
          "promql/rate",
          "promql/regexp",
          "promql/selector",
          "promql/series",
          "promql/syntax",
          "promql/vector_matching",
          "query/cost",
          "rule/dependency",
          "rule/duplicate",
          "rule/for",
          "rule/label",
          "rule/link",
          "rule/name",
          "rule/reject",
          "rule/report"
        ]
      },
      "owners": {},
      "prometheus": [
        {
          "name": "prom1",
          "uri": "http://localhost",
          "timeout": "1s",
          "uptime": "up",
          "include": [
            "rules.yml"
          ],
          "concurrency": 16,
          "rateLimit": 100,
          "required": false
        },
        {
          "name": "prom2",
          "uri": "http://localhost",
          "timeout": "1s",
          "uptime": "up",
          "include": [
            "rules.yml"
          ],
          "concurrency": 16,
          "rateLimit": 100,
          "required": false
        }
      ],
      "rules": [
        {
          "cost": {
            "comment": "this is rule comment",
            "severity": "info"
          }
        },
        {
          "cost": {
            "severity": "warning",
            "maxSeries": 10000
          }
        },
        {
          "cost": {
            "severity": "bug",
            "maxSeries": 20000
          }
        }
      ]
    }
entry:
    path:
        name: rules.yml
        symlinktarget: rules.yml
    filecomments: []
    rulecomments:
        - value:
            match: promql/counter
            position:
                pos:
                    - line: 2
                      firstcolumn: 1
                      lastcolumn: 29
                offset: 15
          type: 10
          offset: 0
        - value:
            match: promql/series
            position:
                pos:
                    - line: 3
                      firstcolumn: 1
                      lastcolumn: 28
                offset: 15
          type: 10
          offset: 0
        - value:
            match: promql/rate
            position:
                pos:
                    - line: 4
                      firstcolumn: 1
                      lastcolumn: 26
                offset: 15
          type: 10
          offset: 0
        - value:
            match: promql/vector_matching(prom1)
            position:
                pos:
                    - line: 5
                      firstcolumn: 1
                      lastcolumn: 44
                offset: 15
          type: 10
          offset: 0
        - value:
            match: promql/vector_matching(prom2)
            position:
                pos:
                    - line: 6
                      firstcolumn: 1
                      lastcolumn: 44
                offset: 15
          type: 10
          offset: 0
        - value:
            match: promql/range_query
            position:
                pos:
                    - line: 7
                      firstcolumn: 1
                      lastcolumn: 33
                offset: 15
          type: 10
          offset: 0
        - value:
            match: rule/duplicate
            position:
                pos:
                    - line: 8
                      firstcolumn: 1
                      lastcolumn: 29
                offset: 15
          type: 10
          offset: 0
        - value:
            match: labels/conflict
            position:
                pos:
                    - line: 9
                      firstcolumn: 1
                      lastcolumn: 30
                offset: 15
          type: 10
          offset: 0
        - value:
            match: alerts/external_labels
            position:
                pos:
                    - line: 10
                      firstcolumn: 1
                      lastcolumn: 37
                offset: 15
          type: 10
          offset: 0
        - value:
            match: promql/impossible
            position:
                pos:
                    - line: 11
                      firstcolumn: 1
                      lastcolumn: 32
                offset: 15
          type: 10
          offset: 0
        - value:
            match: promql/fragile
            position:
                pos:
                    - line: 13
                      firstcolumn: 3
                      lastcolumn: 31
                offset: 15
          type: 10
          offset: 0
        - value:
            match: promql/regexp
            position:
                pos:
                    - line: 14
                      firstcolumn: 3
                      lastcolumn: 30
                offset: 15
          type: 10
          offset: 0
checks:
    - promql/syntax
    - alerts/for
    - alerts/comparison
    - alerts/template
    - rule/dependency
    - group/interval
    - alerts/absent(prom1)
    - promql/features(prom1)
    - alerts/absent(prom2)
    - promql/features(prom2)
    - query/cost(prom1)
    - query/cost(prom2)
    - query/cost(prom1:10000)
    - query/cost(prom2:10000)
    - query/cost(prom1:20000)
    - query/cost(prom2:20000)

---
